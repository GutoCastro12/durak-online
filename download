<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Durak Online ♠ ♥ ♦ ♣</title>
<style>
  :root{
    --felt:#0e6b3d;--felt-d:#0a5230;--felt-l:#14924f;
    --card-bg:#fbfbf4;--card-bd:#cfcfc2;--red:#c62828;--blk:#212121;
    --gold:#e9c452;--gold-d:#b8941f;--panel:rgba(0,0,0,.5);--txt:#f4f4ee;--dim:#bcd0c2;
    --sh:0 4px 14px rgba(0,0,0,.35);
  }
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
  html,body{height:100%;overflow:hidden;}
  body{font-family:'Segoe UI',system-ui,-apple-system,Roboto,sans-serif;
    background:radial-gradient(ellipse at 50% 40%,var(--felt-l),var(--felt) 52%,var(--felt-d) 100%);
    color:var(--txt);user-select:none;touch-action:manipulation;}
  #app{position:relative;width:100vw;height:100vh;}

  /* cards */
  .card{position:absolute;background:var(--card-bg);border:1px solid var(--card-bd);border-radius:8px;
    box-shadow:var(--sh);display:flex;flex-direction:column;justify-content:space-between;padding:4px 5px;
    font-weight:800;line-height:1;transition:transform .18s,box-shadow .18s,left .25s,top .25s;}
  .card .c{display:flex;flex-direction:column;align-items:center;font-size:14px;font-weight:800;}
  .card .c.bot{transform:rotate(180deg);align-self:flex-end;}
  .card .pip{font-size:24px;text-align:center;align-self:center;}
  .card.red{color:var(--red);}.card.black{color:var(--blk);}
  .card.back{background:repeating-linear-gradient(45deg,#7a1f2b 0 7px,#9a2c3a 7px 14px);border-color:#5e1620;}
  .card.back .c,.card.back .pip{visibility:hidden;}
  .card.back::after{content:"";position:absolute;inset:5px;border:2px solid rgba(255,255,255,.32);border-radius:5px;}
  .card.trump{outline:2px solid var(--gold);outline-offset:-1px;}
  .card.sel{cursor:pointer;}
  .card.sel:hover{transform:translateY(-18px);box-shadow:0 12px 22px rgba(0,0,0,.45);z-index:50;}
  .card.picked{transform:translateY(-26px)!important;outline:2.5px solid var(--gold);z-index:51;box-shadow:0 14px 26px rgba(0,0,0,.5);}
  .card.dim{opacity:.5;filter:grayscale(.35);}

  /* seats */
  .seat{position:absolute;transform:translate(-50%,-50%);display:flex;flex-direction:column;align-items:center;gap:3px;transition:opacity .3s;}
  .seat .av{width:46px;height:46px;border-radius:50%;background:var(--panel);border:2px solid rgba(255,255,255,.22);display:flex;align-items:center;justify-content:center;font-size:22px;position:relative;}
  .seat.active .av{border-color:var(--gold);box-shadow:0 0 0 3px rgba(233,196,82,.4);}
  .seat .nm{font-size:12px;font-weight:600;background:var(--panel);padding:2px 9px;border-radius:10px;white-space:nowrap;max-width:120px;overflow:hidden;text-overflow:ellipsis;}
  .seat .ct{font-size:10.5px;color:var(--dim);}
  .seat .role{position:absolute;top:-7px;right:-9px;font-size:8.5px;font-weight:800;padding:2px 5px;border-radius:7px;letter-spacing:.3px;}
  .role.atk{background:#c62828;color:#fff;}.role.def{background:#1565c0;color:#fff;}
  .seat .mini{display:flex;height:24px;margin-top:1px;}
  .seat .mini i{width:15px;height:22px;margin-left:-9px;border-radius:3px;background:repeating-linear-gradient(45deg,#7a1f2b 0 4px,#9a2c3a 4px 8px);border:1px solid #5e1620;}
  .seat .mini i:first-child{margin-left:0;}
  .seat.out{opacity:.38;}.seat.out .nm{text-decoration:line-through;}
  .seat .you{font-size:8.5px;background:var(--gold);color:#1c1c1c;border-radius:6px;padding:1px 5px;font-weight:800;}
  .seat .off{position:absolute;top:-6px;left:-8px;font-size:12px;}

  #table{position:absolute;top:48%;left:50%;transform:translate(-50%,-50%);width:62%;min-height:104px;display:flex;flex-wrap:wrap;gap:10px 16px;justify-content:center;align-items:center;}
  .pair{position:relative;width:60px;height:88px;}
  .pair .card{position:absolute;}.pair .atk{left:0;top:0;}.pair .def{left:15px;top:20px;}

  #deckZone{position:absolute;left:14px;top:34%;transform:translateY(-50%);display:flex;flex-direction:column;align-items:center;gap:7px;z-index:5;}
  #deckStack{position:relative;width:88px;height:90px;}
  #deckStack .card{position:absolute;}
  #deckStack .trumpC{left:24px;top:12px;transform:rotate(92deg);}
  #deckStack .topback{left:0;top:0;}
  #deckInfo{font-size:11.5px;background:var(--panel);padding:3px 10px;border-radius:11px;text-align:center;}
  #discardZone{position:absolute;right:14px;top:34%;transform:translateY(-50%);display:flex;flex-direction:column;align-items:center;gap:6px;font-size:10.5px;color:var(--dim);z-index:5;}
  #discardStack{position:relative;width:70px;height:90px;}

  #handZone{position:absolute;bottom:104px;left:50%;transform:translateX(-50%);height:120px;}
  #handZone .card{bottom:0;}
  #youTag{position:absolute;bottom:228px;left:50%;transform:translateX(-50%);font-size:11px;color:var(--dim);background:var(--panel);padding:2px 10px;border-radius:10px;}

  #actionBar{position:absolute;bottom:24px;left:50%;transform:translateX(-50%);display:flex;gap:11px;align-items:center;z-index:40;flex-wrap:wrap;justify-content:center;max-width:94vw;}
  button.act{font-family:inherit;font-size:14px;font-weight:700;cursor:pointer;border:none;padding:11px 22px;border-radius:24px;color:#1c1c1c;background:var(--gold);box-shadow:var(--sh);transition:transform .1s,filter .15s;}
  button.act:hover{filter:brightness(1.07);}button.act:active{transform:scale(.96);}
  button.act.sec{background:rgba(255,255,255,.92);}button.act.dng{background:#e07a5f;color:#fff;}
  button.act:disabled{opacity:.4;cursor:not-allowed;filter:none;}

  #status{position:absolute;top:14px;left:50%;transform:translateX(-50%);background:var(--panel);padding:8px 20px;border-radius:20px;font-size:14px;font-weight:600;text-align:center;max-width:84vw;z-index:40;}
  #toast{position:absolute;top:56px;left:50%;transform:translateX(-50%);font-size:13px;color:var(--gold);font-weight:700;opacity:0;transition:opacity .25s;z-index:41;pointer-events:none;}

  .overlay{position:absolute;inset:0;background:rgba(0,0,0,.74);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:18px;z-index:100;text-align:center;padding:24px;overflow-y:auto;}
  .overlay h1{font-size:30px;color:var(--gold);text-shadow:0 2px 8px rgba(0,0,0,.6);}
  .overlay h2{font-size:17px;font-weight:500;max-width:520px;line-height:1.5;}
  .overlay .row{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;align-items:center;}
  .overlay input,.overlay select{font-family:inherit;font-size:16px;padding:9px 13px;border-radius:10px;border:none;font-weight:600;}
  .overlay input{width:200px;text-transform:none;}
  .overlay input#code{text-transform:uppercase;letter-spacing:3px;text-align:center;font-weight:800;width:150px;}
  .hidden{display:none!important;}
  .hint{font-size:12px;color:var(--dim);max-width:480px;}
  .card2{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.14);border-radius:14px;padding:18px 20px;display:flex;flex-direction:column;gap:14px;align-items:center;min-width:280px;}
  .seatList{display:flex;flex-direction:column;gap:7px;width:100%;max-width:340px;}
  .seatRow{display:flex;align-items:center;gap:10px;background:var(--panel);padding:8px 12px;border-radius:10px;font-size:14px;}
  .seatRow .dot{width:9px;height:9px;border-radius:50%;background:#888;}
  .seatRow .dot.on{background:#5fe08a;}.seatRow .dot.bot{background:#7aa7e0;}
  .seatRow .who{flex:1;text-align:left;}
  .linkbox{display:flex;gap:8px;width:100%;max-width:360px;}
  .linkbox input{flex:1;font-size:13px;letter-spacing:0;}
  .smallbtn{font-size:13px;padding:8px 14px;border-radius:10px;border:none;background:var(--gold);font-weight:700;cursor:pointer;}
  #logBtn{position:absolute;right:14px;bottom:96px;font-size:11px;background:var(--panel);padding:5px 10px;border-radius:10px;cursor:pointer;z-index:42;}
  #log{position:absolute;right:14px;bottom:128px;width:210px;max-height:42vh;overflow-y:auto;background:var(--panel);border-radius:11px;padding:9px 11px;font-size:11.5px;line-height:1.55;z-index:42;}
  #log .l{margin-bottom:3px;color:var(--dim);}#log .l.big{color:var(--gold);font-weight:600;}
  .sr{color:var(--red);}.sb{color:#2c2c2c;}
  #conn{position:absolute;top:10px;right:12px;font-size:11px;color:var(--dim);z-index:60;}
  #conn.bad{color:#e07a5f;}
</style>
</head>
<body>
<div id="app">
  <div id="conn"></div>

  <!-- HOME -->
  <div id="home" class="overlay">
    <h1>♠ DURAK ONLINE ♥</h1>
    <div class="row" style="align-items:stretch;">
      <div class="card2">
        <b style="font-size:16px;">Criar sala</b>
        <input id="hostName" placeholder="Seu nome" maxlength="14">
        <label style="font-size:14px;">Lugares:
          <select id="numSeats"><option>2</option><option>3</option><option selected>4</option><option>5</option><option>6</option></select>
        </label>
        <button class="act" id="createBtn">Criar e convidar</button>
      </div>
      <div class="card2">
        <b style="font-size:16px;">Entrar numa sala</b>
        <input id="joinName" placeholder="Seu nome" maxlength="14">
        <input id="code" placeholder="CÓDIGO" maxlength="4">
        <button class="act sec" id="joinBtn">Entrar</button>
      </div>
    </div>
    <p class="hint">Crie uma sala, compartilhe o link com os amigos e joguem em tempo real. Lugares vazios podem ser preenchidos por bots.</p>
  </div>

  <!-- LOBBY -->
  <div id="lobby" class="overlay hidden">
    <h1>Sala <span id="lobbyCode" style="letter-spacing:4px;"></span></h1>
    <div class="linkbox">
      <input id="shareLink" readonly>
      <button class="smallbtn" id="copyBtn">Copiar</button>
    </div>
    <div class="seatList" id="seatList"></div>
    <div class="row" id="hostControls">
      <button class="smallbtn" id="addBotBtn">+ Bot</button>
      <button class="smallbtn" id="rmBotBtn">– Bot</button>
      <button class="act" id="startBtn">Começar jogo</button>
    </div>
    <p class="hint" id="lobbyHint">Aguardando jogadores…</p>
  </div>

  <!-- GAME -->
  <div id="game" class="hidden">
    <div id="status"></div>
    <div id="toast"></div>
    <div id="deckZone"><div id="deckStack"></div><div id="deckInfo"></div></div>
    <div id="discardZone"><div id="discardStack"></div><div id="discardLbl">Descarte</div></div>
    <div id="table"></div>
    <div id="youTag">Suas cartas</div>
    <div id="handZone"></div>
    <div id="actionBar"></div>
    <div id="logBtn">📜 Histórico</div>
    <div id="log" class="hidden"></div>
  </div>

  <!-- END -->
  <div id="endOverlay" class="overlay hidden">
    <h1 id="endTitle"></h1>
    <h2 id="endMsg"></h2>
    <button class="act" id="againBtn">Jogar de novo</button>
    <p class="hint" id="endHint"></p>
  </div>
</div>

<script>
const SUIT_RED={'♥':true,'♦':true,'♠':false,'♣':false};
const SUITS=['♠','♥','♦','♣'];
const $=s=>document.querySelector(s);

// ---------- connection ----------
let ws=null, connId=null, myPlayerId=null, mySeat=null, isHost=false, roomCode=null;
let S=null;          // latest server game state
let lobby=null;      // latest lobby state
let picked=[];

function wsURL(){
  const proto = location.protocol==='https:'?'wss':'ws';
  return proto+'://'+location.host;
}
function connect(){
  ws=new WebSocket(wsURL());
  ws.onopen=()=>{ setConn('conectado'); tryAutoJoin(); };
  ws.onclose=()=>{ setConn('reconectando…',true); setTimeout(connect,1500); };
  ws.onerror=()=>{ setConn('erro de conexão',true); };
  ws.onmessage=ev=>{ let m; try{m=JSON.parse(ev.data);}catch(e){return;} onMsg(m); };
}
function setConn(t,bad){ const c=$('#conn'); c.textContent=t; c.className=bad?'bad':''; }
function sendWS(o){ if(ws&&ws.readyState===1) ws.send(JSON.stringify(o)); }

let pendingJoinCode=null;
function tryAutoJoin(){
  // if URL has /sala/CODE, prefill join code
  const m=location.pathname.match(/\/sala\/([A-Za-z0-9]{4})/);
  if(m){ pendingJoinCode=m[1].toUpperCase(); $('#code').value=pendingJoinCode; showHome(); $('#joinName').focus(); }
  // reconnect if we have stored identity
  const saved=loadIdent();
  if(saved && saved.code && saved.playerId){
    sendWS({type:'join', code:saved.code, name:saved.name, playerId:saved.playerId});
  }
}

function onMsg(m){
  if(m.type==='hello'){ connId=m.connId; return; }
  if(m.type==='error'){ toast(m.error||'Erro'); if(/encerrada|não encontrada|cheia|já começou/i.test(m.error)){ clearIdent(); showHome(); } return; }
  if(m.type==='joined'){
    mySeat=m.seat; myPlayerId=m.playerId; isHost=!!m.host; roomCode=m.code;
    saveIdent({code:m.code, playerId:m.playerId, name:($('#hostName').value||$('#joinName').value||'Jogador')});
    history.replaceState(null,'','/sala/'+m.code);
    return;
  }
  if(m.type==='lobby'){ lobby=m; if(!m.started){ showLobby(); renderLobby(); } return; }
  if(m.type==='state'){ S=m; showGame(); render(); if(S.finished) showEnd(); else $('#endOverlay').classList.add('hidden'); return; }
}

// ---------- identity persistence (so refresh reconnects) ----------
function saveIdent(o){ try{ sessionStorage.setItem('durak_id',JSON.stringify(o)); }catch(e){} }
function loadIdent(){ try{ return JSON.parse(sessionStorage.getItem('durak_id')); }catch(e){ return null; } }
function clearIdent(){ try{ sessionStorage.removeItem('durak_id'); }catch(e){} }

// ---------- screen switching ----------
function showHome(){ $('#home').classList.remove('hidden'); $('#lobby').classList.add('hidden'); $('#game').classList.add('hidden'); $('#endOverlay').classList.add('hidden'); }
function showLobby(){ $('#home').classList.add('hidden'); $('#lobby').classList.remove('hidden'); $('#game').classList.add('hidden'); }
function showGame(){ $('#home').classList.add('hidden'); $('#lobby').classList.add('hidden'); $('#game').classList.remove('hidden'); }

// ---------- home actions ----------
$('#createBtn').onclick=()=>{
  const name=$('#hostName').value.trim()||'Anfitrião';
  const n=parseInt($('#numSeats').value);
  sendWS({type:'create', name, numSeats:n});
};
$('#joinBtn').onclick=()=>{
  const name=$('#joinName').value.trim()||'Jogador';
  const code=($('#code').value||'').trim().toUpperCase();
  if(code.length!==4){ toast('Digite o código de 4 letras'); return; }
  sendWS({type:'join', code, name});
};

// ---------- lobby actions ----------
$('#copyBtn').onclick=()=>{ const i=$('#shareLink'); i.select(); try{ navigator.clipboard.writeText(i.value); toast('Link copiado!'); }catch(e){ document.execCommand('copy'); toast('Link copiado!'); } };
$('#addBotBtn').onclick=()=>sendWS({type:'addBot'});
$('#rmBotBtn').onclick=()=>sendWS({type:'removeBot'});
$('#startBtn').onclick=()=>sendWS({type:'start'});
$('#againBtn').onclick=()=>{ if(isHost) sendWS({type:'again'}); else toast('Só o anfitrião reinicia'); };

function renderLobby(){
  $('#lobbyCode').textContent=lobby.code;
  $('#shareLink').value=location.origin+'/sala/'+lobby.code;
  const list=$('#seatList'); list.innerHTML='';
  lobby.seats.forEach(s=>{
    const row=document.createElement('div'); row.className='seatRow';
    let dot='dot', label=s.name;
    if(s.kind==='human'){ dot+=s.connected?' on':''; if(s.idx===mySeat) label+=' (você)'; }
    else if(s.kind==='bot'){ dot+=' bot'; }
    else label='— vazio —';
    row.innerHTML='<span class="'+dot+'"></span><span class="who">'+label+'</span><span style="font-size:11px;color:var(--dim)">'+(s.kind==='human'?'jogador':s.kind==='bot'?'bot':'')+'</span>';
    list.appendChild(row);
  });
  $('#hostControls').style.display=isHost?'flex':'none';
  $('#lobbyHint').textContent=isHost?'Compartilhe o link. Comece quando quiser — lugares vazios viram bots.':'Aguardando o anfitrião começar…';
}

// ===================== GAME RENDER (mirrors single-player look) =====================
function cardEl(c,{back=false,trump=false,w=60,h=88}={}){
  const el=document.createElement('div');
  el.className='card '+(back?'back':(SUIT_RED[c.suit]?'red':'black'))+(trump?' trump':'');
  el.style.width=w+'px';el.style.height=h+'px';
  if(!back){el.innerHTML='<div class="c"><span>'+c.label+'</span><span>'+c.suit+'</span></div><div class="pip">'+c.suit+'</div><div class="c bot"><span>'+c.label+'</span><span>'+c.suit+'</span></div>';}
  return el;
}
function cardId(c){return c.suit+c.rank;}
function isTrump(c){return c.suit===S.trumpSuit;}
function seatSlots(n){
  const W=innerWidth,H=innerHeight;
  const map={
    2:[[50,93],[50,12]],
    3:[[50,93],[15,40],[85,40]],
    4:[[50,93],[12,56],[50,12],[88,56]],
    5:[[50,93],[11,58],[30,15],[70,15],[89,58]],
    6:[[50,93],[10,58],[26,16],[50,11],[74,16],[90,58]],
  }[n];
  return map.map(([x,y])=>({x:x*W/100,y:y*H/100}));
}
// rotate seat indices so *my* seat is always at the bottom (index 0 visually)
function visualOrder(){
  const n=S.players.length; const order=[];
  for(let k=0;k<n;k++) order.push((mySeat+k)%n);
  return order; // order[0] = me (bottom), then clockwise
}

function render(){
  if(!S) return;
  renderSeats(); renderDeck(); renderTable(); renderHand(); renderActions(); renderStatus(); renderLog();
}

function renderSeats(){
  document.querySelectorAll('.seat').forEach(e=>e.remove());
  const order=visualOrder(); const n=order.length;
  const pos=seatSlots(n);
  order.forEach((pi,vi)=>{
    if(vi===0) return; // me = hand at bottom
    const p=S.players[pi];
    const s=document.createElement('div');
    const active=!p.out&&(S.attackerIdx===pi||S.defenderIdx===pi);
    s.className='seat'+(active?' active':'')+(p.out?' out':'');
    s.style.left=pos[vi].x+'px'; s.style.top=pos[vi].y+'px';
    let role='';
    if(!p.out&&S.attackerIdx===pi) role='<span class="role atk">ATK</span>';
    else if(!p.out&&S.defenderIdx===pi) role='<span class="role def">DEF</span>';
    let mini='';for(let k=0;k<Math.min(p.count,9);k++)mini+='<i></i>';
    const icon=p.kind==='bot'?'🤖':'🧑';
    const off=(p.kind==='human'&&p.count>=0&&S.players[pi].disconnected)?'':''; // reserved
    s.innerHTML='<div class="av">'+role+icon+'</div><div class="nm">'+esc(p.name)+'</div><div class="mini">'+mini+'</div><div class="ct">'+(p.out?'fora':p.count+' cartas')+'</div>';
    $('#app').appendChild(s);
  });
}
function esc(t){return (t||'').replace(/[<>&]/g,c=>({'<':'&lt;','>':'&gt;','&':'&amp;'}[c]));}

function renderDeck(){
  const ds=$('#deckStack');ds.innerHTML='';
  if(S.trumpCard){const tc=cardEl(S.trumpCard,{trump:true});tc.classList.add('trumpC');ds.appendChild(tc);}
  if(S.deckCount>1){const b=cardEl(null,{back:true});b.classList.add('topback');ds.appendChild(b);}
  $('#deckInfo').innerHTML='🂠 '+S.deckCount+' no monte &nbsp;·&nbsp; Trunfo <b style="font-size:14px">'+S.trumpSuit+'</b>';
  const dz=$('#discardStack');dz.innerHTML='';
  if(S.discardCount>0){for(let k=0;k<Math.min(3,Math.ceil(S.discardCount/4));k++){const b=cardEl(null,{back:true});b.style.left=(k*4)+'px';b.style.top=(k*2)+'px';b.style.transform='rotate('+(k*5-4)+'deg)';dz.appendChild(b);}}
  $('#discardLbl').textContent='Descarte ('+S.discardCount+')';
}

function renderTable(){
  const t=$('#table');t.innerHTML='';
  for(const pr of S.table){
    const w=document.createElement('div');w.className='pair';
    const a=cardEl(pr.atk,{trump:isTrump(pr.atk)});a.classList.add('atk');w.appendChild(a);
    if(pr.def){const d=cardEl(pr.def,{trump:isTrump(pr.def)});d.classList.add('def');w.appendChild(d);}
    t.appendChild(w);
  }
}

function myHand(){ const me=S.players[mySeat]; return (me&&me.hand)?me.hand:[]; }

function renderHand(){
  const hz=$('#handZone');hz.innerHTML='';
  const hand=myHand();const n=hand.length;
  const cardW=60;const maxW=Math.min(innerWidth*0.92,720);
  const step=n>1?Math.min(cardW+4,(maxW-cardW)/(n-1)):0;
  hz.style.width=(cardW+step*(n-1))+'px';
  const pset=new Set(picked);
  hand.forEach((c,idx)=>{
    const el=cardEl(c,{trump:isTrump(c)});
    el.style.left=(idx*step)+'px';
    const ok=cardPlayable(c);
    if(ok)el.classList.add('sel');else el.classList.add('dim');
    if(pset.has(cardId(c)))el.classList.add('picked');
    el.onclick=()=>onCardClick(c);
    hz.appendChild(el);
  });
}

function L(){ return S.legal||{}; }
function myTurn(){ return L().youract; }

function cardPlayable(c){
  if(!S||S.finished||!myTurn())return false;
  const lg=L();
  if(lg.canDefend && lg.defendMap){
    for(const k in lg.defendMap){ if(lg.defendMap[k].includes(cardId(c))) return true; }
  }
  if(lg.canTransfer && c.rank===lg.transferRank) return true;
  if(lg.canAttack && lg.attackRanks.includes(c.rank)) return true;
  return false;
}

function onCardClick(c){
  if(!cardPlayable(c))return;
  const lg=L(); const id=cardId(c);
  // Defender: clicking defends immediately unless it's a transfer-rank card (toggle for transfer)
  if(S.phase==='defense' && S.defenderIdx===mySeat){
    const transferable = lg.canTransfer && c.rank===lg.transferRank;
    if(transferable){
      const i=picked.indexOf(id); if(i>=0)picked.splice(i,1); else picked.push(id);
      render(); return;
    }
    // defend: find an undefended pair this card can cover (lowest rank target)
    if(lg.defendMap){
      const targets=Object.keys(lg.defendMap).filter(ti=>lg.defendMap[ti].includes(id))
        .map(ti=>({ti:+ti, rank:S.table[+ti].atk.rank})).sort((a,b)=>a.rank-b.rank);
      if(targets.length){ sendWS({type:'action',action:'defend',pairIndex:targets[0].ti,cardId:id}); picked=[]; }
    }
    return;
  }
  // attack / co-attack: toggle same-rank multi-select
  const i=picked.indexOf(id);
  if(i>=0)picked.splice(i,1);
  else{
    if(picked.length){ const first=myHand().find(x=>cardId(x)===picked[0]); if(first&&first.rank!==c.rank)picked=[id]; else picked.push(id); }
    else picked=[id];
  }
  render();
}

function btn(label,fn,cls=''){const b=document.createElement('button');b.className='act '+cls;b.textContent=label;b.onclick=fn;return b;}

function renderActions(){
  const bar=$('#actionBar');bar.innerHTML='';
  if(!S||S.finished||!myTurn())return;
  const lg=L();
  if(lg.canAttack){
    bar.appendChild(btn(S.table.length===0?'Atacar':'Adicionar ataque',()=>{
      if(!picked.length){toast('Selecione ao menos uma carta');return;}
      const cards=picked.map(id=>myHand().find(c=>cardId(c)===id)).filter(Boolean);
      if(new Set(cards.map(c=>c.rank)).size>1){toast('As cartas devem ter o mesmo valor');return;}
      sendWS({type:'action',action:'attack',cardIds:picked.slice()}); picked=[];
    }));
  }
  if(lg.canTransfer && picked.length){
    const cards=picked.map(id=>myHand().find(c=>cardId(c)===id)).filter(Boolean);
    if(cards.length && cards.every(c=>c.rank===lg.transferRank)){
      bar.appendChild(btn('Transferir →',()=>{ sendWS({type:'action',action:'transfer',cardIds:picked.slice()}); picked=[]; }));
    }
  }
  if(lg.canTake){
    bar.appendChild(btn('Pegar cartas',()=>{ sendWS({type:'action',action:'take'}); picked=[]; },'dng'));
    const h=document.createElement('span');h.className='hint';h.style.alignSelf='center';h.textContent='Toque numa carta para defender';bar.appendChild(h);
  }
  if(lg.canPass){
    bar.appendChild(btn('Passar',()=>{ sendWS({type:'action',action:'pass'}); picked=[]; },'sec'));
  }
}

function nameOf(idx){ const p=S.players[idx]; return p?p.name:('Jogador '+idx); }
function renderStatus(){
  let s='';
  if(S.finished){ s='Fim de jogo'; }
  else if(myTurn()){
    const lg=L();
    if(S.phase==='defense'&&S.defenderIdx===mySeat) s='Defenda-se!';
    else if(lg.canAttack&&S.table.length===0) s='Sua vez! Ataque '+nameOf(S.defenderIdx);
    else if(lg.canAttack) s='Adicione cartas ao ataque ou passe';
    else s='Sua vez';
  } else {
    s=nameOf(S.attackerIdx)+' ataca '+nameOf(S.defenderIdx);
  }
  $('#status').textContent=s;
}

let toastT=null;
function toast(m){const t=$('#toast');t.textContent=m;t.style.opacity=1;clearTimeout(toastT);toastT=setTimeout(()=>t.style.opacity=0,1700);}
function renderLog(){ if(!S.log)return; $('#log').innerHTML=S.log.map(e=>'<div class="l'+(e.big?' big':'')+'">'+e.msg+'</div>').join(''); }
$('#logBtn').onclick=()=>$('#log').classList.toggle('hidden');

const ORD=['','primeiro','segundo','terceiro','quarto','quinto','sexto'];
function showEnd(){
  $('#endOverlay').classList.remove('hidden');
  const N=S.players.length;
  let place=S.finishOrder.indexOf(mySeat); place=place<0?N:place+1;
  const isDurak=S.durakIdx===mySeat;
  const isTie=S.durakIdx==null;
  if(place===1&&!isDurak){ $('#endTitle').textContent='🏆 Você venceu!'; $('#endMsg').textContent='Você foi o primeiro a se livrar de todas as cartas. Mandou muito bem!'; }
  else if(isDurak){ $('#endTitle').textContent='😖 Você é o Durak!'; $('#endMsg').textContent='Você ficou com as últimas cartas. Na próxima você começa atacando — hora da revanche!'; }
  else if(isTie&&place>=N-1){ $('#endTitle').textContent='🤝 Empate!'; $('#endMsg').textContent='Os últimos ficaram sem cartas ao mesmo tempo. Ninguém é o Durak!'; }
  else{ const w=ORD[place]||(place+'º'); $('#endTitle').textContent='Você ficou em '+w+'!'; $('#endMsg').textContent='Você se livrou de todas as cartas em '+w+' lugar. O Durak foi '+(S.durakIdx!=null?nameOf(S.durakIdx):'ninguém')+'.'; }
  $('#endHint').textContent=isHost?'Toque em "Jogar de novo" para reiniciar com os mesmos jogadores.':'Aguardando o anfitrião reiniciar…';
  $('#againBtn').style.display=isHost?'':'none';
}

addEventListener('resize',()=>{ if(S&&!$('#game').classList.contains('hidden')) render(); });

// boot
connect();
</script>
